# EditorConfig - consistent formatting across editors.
# Override these only at the per-subproject level if needed.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
trim_trailing_whitespace = true

[*.py]
indent_size = 4
max_line_length = 100

[*.{md,rst,txt}]
indent_size = 2
trim_trailing_whitespace = false  # markdown sometimes uses trailing space for line breaks

[Makefile]
indent_style = tab

[*.{json,yml,yaml,toml}]
indent_size = 2

[*.sh]
indent_size = 4

[*.tex]
indent_size = 2
max_line_length = 100
